# ============================================
# BP Monitor - Environment Variables
# ============================================

# --- Database ---
# SQLite (dev): sqlite:///./blood_pressure.db
# PostgreSQL (prod): postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./blood_pressure.db

# --- Security ---
SECRET_KEY=your-jwt-secret-key
ENCRYPTION_KEY=your-fernet-encryption-key
API_KEYS=bp-mobile-app-key,bp-web-app-key

# --- External Services ---
GOOGLE_AI_API_KEY=your-gemini-api-key

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=BPMonitor_Bot
# Bot mode: polling (VPS/local), webhook (serverless), disabled
BOT_MODE=polling

# --- Webhook (only when BOT_MODE=webhook) ---
# WEBHOOK_URL=https://your-api-domain.com
# WEBHOOK_SECRET=your-random-secret

# --- Redis (optional, for serverless/production) ---
# REDIS_URL=redis://localhost:6379/0

# --- Timezone ---
APP_TIMEZONE=Asia/Bangkok

# --- Table Creation ---
# Set to false when using migrations in production
AUTO_CREATE_TABLES=true

# --- OTP ---
# Set to true to skip OTP verification (dev only!)
# BYPASS_OTP=true

# --- Frontend ---
# NEXT_PUBLIC_API_URL=http://localhost:8888/api/v1
# NEXT_PUBLIC_API_KEY=bp-web-app-key

# --- CORS ---
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
